# --- Project Specific ---
build/              # Allt som skapas när du kör 'cmake' och 'make'
bin/                # Färdiga körbara filer
lib/                # Om ni lägger externa bibliotek här manuellt

# --- Compilation and Objects ---
*.o
*.obj
*.d
*.elf
*.gch
*.pch

# --- Executables and Libraries ---
*.exe
*.out
*.app
*.dylib
*.so
*.so.*
*.dll
*.lib
*.a
*.la
*.lo

# --- CMake (Viktigt!) ---
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
Makefile
_CPack_Packages/
CPackConfig.cmake
CPackSourceConfig.cmake

# --- IDEs (VS Code & Visual Studio) ---
.vscode/            # Inställningar för editorn (ofta unika per dator)
.vs/                # Visual Studio (Windows-vännens skräpfil)
*.user
*.suo
*.sln
*.vcxproj
*.filters

# --- OS Junk (Mac & Windows) ---
.DS_Store           # Mac-specifik fil som skapas i varje mapp
Desktop.ini         # Windows-motsvarighet
Thumbs.db           # Windows miniatyrbilder

# --- Debug & Logs ---
*.log
*.dSYM/             # Mac debug-symboler
*.pdb
*.idb